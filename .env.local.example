# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Auth — set this in Supabase Dashboard → Auth → URL Configuration
# Site URL: http://localhost:3000 (dev) / https://yourdomain.com (prod)
# Redirect URLs: http://localhost:3000/auth/callback

# Admin (simple password protection)
ADMIN_PASSWORD=change-me-in-production

# Email — Resend (https://resend.com — free tier: 3k emails/mo)
RESEND_API_KEY=re_...
# If unset, emails are skipped but logged to console (safe for local dev)
